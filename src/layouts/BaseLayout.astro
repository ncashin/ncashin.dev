---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  navLogoPreload?: string;
  /** Path (site root–relative) for link previews, e.g. /images/og.png */
  ogImagePath?: string;
}

const {
  title,
  description,
  navLogoPreload = "/images/logos/natalie-no-bg.svg",
  ogImagePath = "/images/logos/natalie-no-bg.svg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImagePath, canonicalURL.origin).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/images/logos/natalie.svg" />
    <link rel="preload" as="image" href={navLogoPreload} />
    <link
      rel="preload"
      href="/fonts/Geist-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="preload" as="image" href="/images/logos/x.svg" />
    <link rel="preload" as="image" href="/images/logos/mail.svg" />
    <link rel="preload" as="image" href="/images/logos/spellbook.svg" />
    <link rel="preload" as="image" href="/images/logos/c-core.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ffffff" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Natalie Cashin" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
  </head>
  <body>
    <div class="relative z-10 mx-auto flex max-w-xl px-8 pb-0 pt-16">
      <div class="flex min-h-screen min-w-0 max-w-xl flex-1 flex-col gap-16">
        <slot />
      </div>
    </div>
    <img
      src="/images/cybersigil.png"
      alt=""
      width="669"
      height="360"
      decoding="async"
      loading="lazy"
      aria-hidden="true"
      style="visibility:hidden;position:absolute;width:0;height:0;"
      class="pointer-events-none"
    />
  </body>
</html>
