---
/**
 * C-CORE mark scale in the logo box. Spellbook’s SVG uses a ~10×10 region in 16×16 (~62.5%);
 * C-CORE is slightly larger (12/16) so the ring stays readable.
 */
const cCoreMarkFraction = 12 / 16;

const entries = [
  {
    company: "Spellbook",
    href: "https://spellbook.legal",
    logo: "/images/logos/spellbook.svg",
    logoAlt: "Spellbook",
    title: "Software Developer / AI Operations Lead",
    period: "2025 - 2026",
    logoInsetFraction: 1,
  },
  {
    company: "C-CORE",
    href: "https://www.c-core.ca",
    logo: "/images/logos/c-core.png",
    logoAlt: "C-CORE",
    title: "Intern / Junior Software Developer",
    period: "2024",
    logoInsetFraction: cCoreMarkFraction,
  },
] as const;
---

<section id="experience" class="flex flex-col">
  <h2
    class="pb-6 text-sm tracking-apple-14 text-[hsl(var(--secondary-foreground))]"
  >
    Experience
  </h2>
  <div
    class="-mx-[0.365rem] -mt-1 flex flex-col text-sm font-medium tracking-apple-14 text-[hsl(var(--foreground))]"
  >
    {
      entries.map((e) => (
        <a
          href={e.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex min-w-0 flex-row items-start gap-x-2.5 py-1.5 pl-2 pr-2.5 text-[hsl(var(--foreground))] no-underline [-webkit-tap-highlight-color:transparent] outline-offset-2 transition-[background-color,color] duration-150 ease-out motion-reduce:transition-none hover:bg-zinc-100 active:bg-zinc-100 md:items-center"
        >
          <span class="inline-flex min-w-0 shrink-0 items-center gap-2">
            <span
              class:list={[
                "inline-flex h-5 w-5 shrink-0 items-center justify-center",
                e.logoInsetFraction < 1 && "bg-[hsl(var(--background))]",
              ]}
            >
              <img
                src={e.logo}
                alt=""
                width="20"
                height="20"
                decoding="async"
                class:list={[
                  "shrink-0 object-contain",
                  e.logoInsetFraction >= 1 ? "h-5 w-5" : "h-auto w-auto",
                ]}
                style={
                  e.logoInsetFraction < 1
                    ? {
                        maxHeight: `${e.logoInsetFraction * 100}%`,
                        maxWidth: `${e.logoInsetFraction * 100}%`,
                      }
                    : undefined
                }
              />
            </span>
            <span>{e.company}</span>
          </span>
          <span class="min-w-0 flex-1 font-normal text-[hsl(var(--secondary-foreground))] transition-colors duration-150 ease-out motion-reduce:transition-none group-hover:text-[hsl(var(--foreground))]">
            {e.title}
          </span>
          <span class="shrink-0 tabular-nums font-normal text-[hsl(var(--secondary-foreground))] transition-colors duration-150 ease-out motion-reduce:transition-none group-hover:text-[hsl(var(--foreground))]">
            {e.period}
          </span>
        </a>
      ))
    }
  </div>
</section>
