---
const entries = [
  {
    company: "Spellbook",
    href: "https://spellbook.legal",
    logo: "/images/logos/spellbook.svg",
    logoAlt: "Spellbook",
    title: "Software Developer / AI Operations Lead",
    period: "2025 - 2026",
  },
  {
    company: "C-CORE",
    href: "https://www.c-core.ca",
    logo: "/images/logos/c-core.png",
    logoAlt: "C-CORE",
    title: "Intern / Junior Software Developer",
    period: "2024",
  },
];
---

<section id="experience" class="flex flex-col">
  <h2
    class="pb-4 text-sm tracking-tight text-[hsl(var(--secondary-foreground))]"
  >
    Experience
  </h2>
  <div class="-mt-1 flex flex-col">
    {
      entries.map((e) => (
        <a
          href={e.href}
          target="_blank"
          rel="noopener noreferrer"
          class=" flex flex-row items-center justify-between gap-4 rounded-xs px-2.5 py-2 text-sm font-medium text-[hsl(var(--foreground))] no-underline transition-colors hover:bg-[hsl(var(--muted))]"
        >
          <div class="flex min-w-0 flex-row flex-wrap items-center gap-x-3 gap-y-1.5">
            <span class="inline-flex shrink-0 items-center gap-3">
              <img
                src={e.logo}
                alt=""
                width="20"
                height="20"
                decoding="async"
                class="h-5 w-5 shrink-0"
              />
              {e.company}
            </span>
            <span class="text-[hsl(var(--secondary-foreground))]">
              {e.title}
            </span>
          </div>
          <span class="shrink-0 font-medium tracking-tighter tabular-nums text-[hsl(var(--muted-foreground))]">
            {e.period}
          </span>
        </a>
      ))
    }
  </div>
</section>
