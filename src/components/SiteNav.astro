---
interface Props {
  logoSrc?: string;
}

const { logoSrc = "/images/logos/natalie.svg" } = Astro.props;
---

<nav class="flex items-center gap-3.5" aria-label="Site">
  <a class="flex items-center gap-3.5" href="/">
    <img
      src={logoSrc}
      alt="Natalie"
      width="32"
      height="32"
      class="h-8 w-8 shrink-0"
      fetchpriority="high"
      decoding="sync"
    />
    <span
      class="text-base font-medium tracking-tight text-[hsl(var(--foreground))]"
    >
      Natalie Cashin
    </span>
  </a>
</nav>
